# LLM endpoint — can be Ollama or any OpenAI-compatible API
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=ollama

# SQLite database location (relative to the backend directory)
DATABASE_URL=sqlite+aiosqlite:///./promptlab.db

# CORS — set to the Vite dev server origin
CORS_ORIGINS=http://localhost:5173
